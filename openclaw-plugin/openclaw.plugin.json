{
  "id": "lore",
  "name": "Lore",
  "description": "Primary Lore memory system for fixed boot baseline, recall, and cross-session project knowledge.",
  "version": "1.3.5",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "lore_status",
      "lore_boot",
      "lore_get_node",
      "lore_search",
      "lore_list_domains",
      "lore_create_node",
      "lore_update_node",
      "lore_delete_node",
      "lore_move_node"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "baseUrl": {
        "type": "string"
      },
      "apiToken": {
        "type": "string"
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 120000
      },
      "defaultDomain": {
        "type": "string"
      },
      "injectPromptGuidance": {
        "type": "boolean"
      },
      "startupHealthcheck": {
        "type": "boolean"
      },
      "recallEnabled": {
        "type": "boolean"
      },
      "minDisplayScore": {
        "type": "number"
      },
      "maxDisplayItems": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "scorePrecision": {
        "type": "integer",
        "minimum": 0,
        "maximum": 4
      },
      "excludeBootFromResults": {
        "type": "boolean"
      }
    }
  },
  "uiHints": {
    "baseUrl": {
      "label": "Lore API Base URL",
      "placeholder": "http://127.0.0.1:18901"
    },
    "apiToken": {
      "label": "Lore API Token",
      "sensitive": true
    },
    "timeoutMs": {
      "label": "Timeout (ms)"
    },
    "defaultDomain": {
      "label": "Default Domain",
      "placeholder": "core"
    },
    "injectPromptGuidance": {
      "label": "Inject Prompt Guidance"
    },
    "startupHealthcheck": {
      "label": "Startup Health Check"
    },
    "recallEnabled": {
      "label": "Enable Recall Injection"
    },
    "minDisplayScore": {
      "label": "Recall Min Display Score"
    },
    "maxDisplayItems": {
      "label": "Recall Max Display Items"
    },
    "scorePrecision": {
      "label": "Recall Score Precision"
    },
    "excludeBootFromResults": {
      "label": "Exclude Boot Nodes From Recall Results"
    }
  }
}
