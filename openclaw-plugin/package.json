{
  "name": "@local/lore",
  "version": "1.3.5",
  "description": "Lore memory plugin for OpenClaw with fixed boot baseline and recall hooks",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "esbuild index.ts api.ts tools.ts hooks.ts uri.ts formatters.ts --platform=node --format=esm --outdir=dist --target=es2022"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
